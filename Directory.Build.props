<Project>

  <PropertyGroup>
    <RootDirectory>$(MSBuildThisFileDirectory)</RootDirectory>
  </PropertyGroup>

  <PropertyGroup>
    <UseArtifactsOutput>true</UseArtifactsOutput>
    <ArtifactsPath>$(RootDirectory)artifacts</ArtifactsPath>
  </PropertyGroup>

  <PropertyGroup>
    <EnableSourceLink>false</EnableSourceLink>
  </PropertyGroup>

</Project>
